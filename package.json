{
  "name": "sasaeru",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "firebase-admin": "^13.10.0",
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "jest --testPathPattern=tests/ --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^nodemailer$": "<rootDir>/node_modules/nodemailer",
      "^firebase-admin$": "<rootDir>/node_modules/firebase-admin"
    }
  }
}
