# Firebase サービスアカウントキー（機密情報 - 絶対にコミットしない）
*firebase-adminsdk*.json
serviceAccountKey.json

# ローカル設定ファイル（Slack Webhook / EmailJS / Cloudinary キーを含む）
config.js

# 依存パッケージ
node_modules/
netlify/functions/*/node_modules/
netlify/functions/*/package-lock.json

# Firebase Emulator / CLI logs
firebase-debug.log
firestore-debug.log
ui-debug.log

# Netlify デプロイ用の生成物（build command が生成）
dist/

# Claude Code ローカル作業ディレクトリ
.claude/
