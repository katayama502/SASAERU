rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 認証済みユーザー
    function isAuth() {
      return request.auth != null;
    }

    // Custom Claims による管理者チェック
    // Firebase Admin SDK で setCustomUserClaims(uid, { admin: true }) を実行して付与
    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    // 自分がオーナーかチェック（owner_uid と照合）
    function isOwnerOf(orgId) {
      return isAuth() &&
        get(/databases/$(database)/documents/organizations/$(orgId)).data.owner_uid == request.auth.uid;
    }

    // organizations
    match /organizations/{orgId} {
      // 公開中は誰でも1件取得可 / 認証済みなら取得可
      allow get:    if resource.data.status == "public" || isAuth();
      // リスト: 公開クラブは未認証でも取得可（トップページの一覧表示に必要）
      //         認証済みはすべて取得可（マイページのowner_uid照合 + 管理者の全件取得）
      //         ※ 未認証で pending/rejected 団体のメール等が漏洩しないよう isAuth() を要求
      allow list:   if resource.data.status == "public" || isAuth();
      // 作成: 認証済みユーザーが自分のowner_uidで、かつstatus=pendingのみ
      allow create: if isAuth()
                    && request.resource.data.owner_uid == request.auth.uid
                    && request.resource.data.status == "pending";
      // 更新: 管理者 or 自分のオーナー
      allow update: if isAdmin() || isOwnerOf(orgId);
      // 削除: 管理者のみ
      allow delete: if isAdmin();
    }

    // organizations/{orgId}/menus サブコレクション（支援メニュー）
    match /organizations/{orgId}/menus/{menuId} {
      // 1件取得: 公開メニューは誰でも / オーナーまたは管理者は全て
      allow get:    if resource.data.status == "public" || isOwnerOf(orgId) || isAdmin();
      // 一覧取得: 公開メニューは未認証でも取得可 / オーナーまたは管理者は非公開含む全て取得可
      allow list:   if resource.data.status == "public" || isOwnerOf(orgId) || isAdmin();
      // 作成・更新: オーナー または 管理者（強制非公開など）
      allow create, update: if isOwnerOf(orgId) || isAdmin();
      // 削除: オーナーまたは管理者
      allow delete: if isOwnerOf(orgId) || isAdmin();
    }

    // posts（活動日記）
    match /posts/{postId} {
      // 誰でも読める（公開コンテンツ）
      allow read:         if true;
      // 作成: 認証済みユーザーが自分のowner_uidで作成
      allow create:       if isAuth()
                          && request.resource.data.owner_uid == request.auth.uid;
      // 更新・削除: 自分の投稿のみ
      allow update, delete: if isAuth()
                            && resource.data.owner_uid == request.auth.uid;
    }

    // inquiries（支援申請）
    match /inquiries/{inquiryId} {
      // S-1: 作成時に必須フィールドと型を検証（スパム対策）
      allow create: if request.resource.data.keys().hasAll(['org_id','company_name','sender_email','status'])
                    && request.resource.data.status == 'new'
                    && request.resource.data.company_name is string
                    && request.resource.data.company_name.size() > 0
                    && request.resource.data.company_name.size() <= 200
                    && request.resource.data.sender_email is string
                    && request.resource.data.sender_email.matches('.*@.*\\..*');
      // 読み取り: 管理者 または 問い合わせ先の団体オーナー
      allow get, list: if isAdmin()
                       || (isAuth() && isOwnerOf(resource.data.org_id));
      // 更新（対応ステータス変更）: 管理者 または 問い合わせ先の団体オーナー
      allow update: if isAdmin()
                    || (isAuth() && isOwnerOf(resource.data.org_id));
      // 削除: 管理者のみ
      allow delete: if isAdmin();
    }

    // contacts（お問い合わせ）— 管理者のみ閲覧・操作可
    match /contacts/{contactId} {
      // S-1: 必須フィールドと基本バリデーション
      allow create: if request.resource.data.keys().hasAll(['name','email','message'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0;
      allow read, update, delete: if isAdmin();
    }
  }
}
