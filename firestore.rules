rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 認証済みユーザー
    function isAuth() {
      return request.auth != null;
    }

    // Custom Claims による管理者チェック
    // Firebase Admin SDK で setCustomUserClaims(uid, { admin: true }) を実行して付与
    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    // 自分がオーナーかチェック（owner_uid と照合）
    function isOwnerOf(orgId) {
      return isAuth() &&
        get(/databases/$(database)/documents/organizations/$(orgId)).data.owner_uid == request.auth.uid;
    }

    // organizations
    match /organizations/{orgId} {
      // 公開中は誰でも1件取得可 / 管理者は全件取得可 / オーナーは自分の団体のみ取得可
      // S-1: isAuth()だけでは審査中・却下団体のPIIが全認証ユーザーに漏洩するため修正
      // ※ isOwnerOf(orgId) を使わず resource.data で直接チェック（isOwnerOf は get() を呼ぶため
      //   メニュールールから isOwnerOf→get→org_get_rule→isOwnerOf の循環が起きる可能性を排除）
      allow get:    if resource.data.status == "public" || isAdmin()
                    || (isAuth() && resource.data.owner_uid == request.auth.uid);
      // リスト: 公開クラブは未認証でも取得可 / 管理者は全件 / オーナーは自分のドキュメントのみ
      //         resource.data.owner_uid を使うことで isOwnerOf の余分な get() を回避
      allow list:   if resource.data.status == "public"
                    || isAdmin()
                    || (isAuth() && resource.data.owner_uid == request.auth.uid);
      // 作成: 認証済みユーザーが自分のowner_uidで、かつstatus=pendingのみ
      allow create: if isAuth()
                    && request.resource.data.owner_uid == request.auth.uid
                    && request.resource.data.status == "pending";
      // 更新: 管理者はすべてのフィールドを変更可
      //       オーナーは指定フィールドのみ変更可 / statusは'pending'への変更（再申請）のみ許可
      // S-2 / M-4: hasOnly制限 + フィールド値バリデーション（サイズ・フォーマット）
      allow update: if isAdmin()
                    || (isOwnerOf(orgId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'name','category','area','main_image','tags',
                             'activity_how','updated_at','status'
                           ])
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.name.size() <= 100
                        && (request.resource.data.status == resource.data.status
                            || request.resource.data.status == 'pending'));
      // 削除: 管理者のみ
      allow delete: if isAdmin();
    }

    // organizations/{orgId}/menus サブコレクション（支援メニュー）
    match /organizations/{orgId}/menus/{menuId} {
      // 1件取得: 公開メニューは誰でも / オーナーまたは管理者は全て
      // owner_uid が付いた新メニューは resource.data で直接判定、旧メニューは isOwnerOf フォールバック
      allow get:    if resource.data.status == "public"
                    || resource.data.owner_uid == request.auth.uid
                    || isOwnerOf(orgId) || isAdmin();
      // 一覧取得: 公開メニューは未認証でも取得可 / オーナーまたは管理者は非公開含む全て取得可
      allow list:   if resource.data.status == "public"
                    || resource.data.owner_uid == request.auth.uid
                    || isOwnerOf(orgId) || isAdmin();
      // 作成・更新: オーナー（許可フィールドのみ）または 管理者（強制非公開など全フィールド）
      // M-3: hasOnly でオーナーによる任意フィールド書き込みを防止
      // owner_uid をメニュードキュメントに保持することで、update/delete で get() 呼び出し不要にする
      allow create: if isAdmin()
                    || (isOwnerOf(orgId)
                        && request.resource.data.keys().hasOnly([
                             'title','support_type','target_amount','description',
                             'return_merit','status','created_at','updated_at','owner_uid'
                           ])
                        && request.resource.data.owner_uid == request.auth.uid);
      // update/delete: resource.data.owner_uid が一致すれば get() 不要で判定
      //                owner_uid なし（旧メニュー）は isOwnerOf フォールバック
      allow update: if isAdmin()
                    || (resource.data.owner_uid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'title','support_type','target_amount','description',
                             'return_merit','status','updated_at'
                           ]))
                    || (isOwnerOf(orgId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'title','support_type','target_amount','description',
                             'return_merit','status','updated_at'
                           ]));
      // 削除: resource.data.owner_uid が一致、または旧メニューは isOwnerOf フォールバック
      allow delete: if isAdmin()
                    || resource.data.owner_uid == request.auth.uid
                    || isOwnerOf(orgId);
    }

    // posts（活動日記）
    match /posts/{postId} {
      // 誰でも読める（公開コンテンツ）
      allow read:         if true;
      // 作成: 認証済みユーザーが自分のowner_uidで作成
      allow create:       if isAuth()
                          && request.resource.data.owner_uid == request.auth.uid;
      // 更新: 自分の投稿のみ / owner_uidは変更不可（乗っ取り防止）
      // S-4: owner_uid の不変チェックを追加
      allow update:       if isAuth()
                          && resource.data.owner_uid == request.auth.uid
                          && request.resource.data.owner_uid == resource.data.owner_uid;
      // 削除: 自分の投稿のみ
      allow delete:       if isAuth()
                          && resource.data.owner_uid == request.auth.uid;
    }

    // inquiries（支援申請）
    match /inquiries/{inquiryId} {
      // S-1 / M-2: 必須フィールド検証 + hasOnly で余分フィールド書き込みを防止
      allow create: if request.resource.data.keys().hasAll(['org_id','company_name','sender_email','status'])
                    && request.resource.data.keys().hasOnly([
                         'org_id','company_name','pic_name','sender_email',
                         'phone','message','status','created_at'
                       ])
                    && request.resource.data.status == 'new'
                    && request.resource.data.company_name is string
                    && request.resource.data.company_name.size() > 0
                    && request.resource.data.company_name.size() <= 200
                    && request.resource.data.sender_email is string
                    && request.resource.data.sender_email.matches('.*@.*\\..*');
      // 読み取り: 管理者 または 問い合わせ先の団体オーナー
      allow get, list: if isAdmin()
                       || (isAuth() && isOwnerOf(resource.data.org_id));
      // 更新（対応ステータス変更）: 管理者 または 問い合わせ先の団体オーナー
      allow update: if isAdmin()
                    || (isAuth() && isOwnerOf(resource.data.org_id));
      // 削除: 管理者のみ
      allow delete: if isAdmin();
    }

    // contacts（お問い合わせ）— 管理者のみ閲覧・操作可
    match /contacts/{contactId} {
      // S-1 + S-5 + M-1: hasOnly で read_at など管理フィールドの不正書き込みを防止
      allow create: if request.resource.data.keys().hasAll(['name','email','message'])
                    && request.resource.data.keys().hasOnly(['name','email','message','created_at'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000;
      allow read, update, delete: if isAdmin();
    }
  }
}
